cronbach_alpha <- function(data, groups = numeric()) {
num_items <- ncol(data)
if (length(groups) == 0) {
groups <- rep(1, num_items)
warning("No item grouping specified. Cronbach's alpha caluclated assuming all items in same group.",
call. = FALSE)
}
alphas <- numeric(max(groups))
for (i in seq_len(alphas)) {
group_data <- data[groups == i]
group_items <- ncol(group_data)
tot_col <- rowSums(group_data)
tot_var <- var(tot_col)
sum_var <- sum(sapply(group_data, var))
alphas[i] <- ((group_items) / (group_items - 1)) * ((tot_var - sum_var) / tot_var)
}
return(alphas)
}
cronbach_alpha(test)
