c_alpha_calc <- function(data) {
num_items <- ncol(data)
tot_col <- rowSums(data)
tot_var <- var(tot_col)
sum_item_var <- sum(sapply(data, var))
(num_items / (num_items - 1)) * ((tot_var - sum_item_var) / tot_var)
}
